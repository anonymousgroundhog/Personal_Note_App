# Electron Development Environment Variables

# Set to "true" when running in Electron dev mode
ELECTRON_DEV=false

# Docker: REQUIRED when running with docker-compose
# Copy this file to .env and set HOST_HOME to your actual home directory
# This allows the container to access your files for git sync, vaults, and SSH keys
#
# Examples:
#   Linux/Mac:    HOST_HOME=/home/username  or  /Users/username
#   Windows+WSL:  HOST_HOME=/home/username
#
# IMPORTANT: The container will also mount your ~/.ssh directory (read-only) for git SSH authentication.
# Make sure you have SSH keys set up for GitHub (id_rsa or id_ed25519 in ~/.ssh)
HOST_HOME=/home/username

# Git server configuration
GIT_SERVER_PORT=3001
GIT_SERVER_HOST=localhost

# App data directory (relative to user home)
APP_DATA_DIR=.personal-note-app

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Development/Production
NODE_ENV=development
