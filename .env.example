# Electron Development Environment Variables

# Set to "true" when running in Electron dev mode
ELECTRON_DEV=false

# Docker: paths on your HOST machine (copy to .env and set these before running docker compose)
# HOST_HOME=/home/yourname
# NOTES_DIR=/home/yourname/Notes
# ANDROID_SDK_ROOT=/home/yourname/Android/Sdk

# Git server configuration
GIT_SERVER_PORT=3001
GIT_SERVER_HOST=localhost

# App data directory (relative to user home)
APP_DATA_DIR=.personal-note-app

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Development/Production
NODE_ENV=development
