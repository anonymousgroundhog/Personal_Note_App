{
  "name": "personal-note-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Personal Note App Team",
    "email": "support@personalnoteapp.local"
  },
  "description": "A comprehensive personal note-taking and productivity application",
  "scripts": {
    "dev": "node git-server.mjs & vite",
    "dev:electron": "npm run tsc:electron && concurrently \"vite\" \"sleep 2 && ELECTRON_DEV=true electron .\"",
    "tsc:electron": "tsc -p tsconfig.electron.json",
    "git-server": "node git-server.mjs",
    "build": "vite build",
    "build:electron": "npm run tsc:electron && vite build && electron-builder",
    "build:electron:win": "npm run tsc:electron && vite build && electron-builder --win",
    "build:electron:mac": "npm run tsc:electron && vite build && electron-builder --mac",
    "build:electron:linux": "npm run tsc:electron && vite build && electron-builder --linux",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "electron": "^31.0.0",
    "electron-builder": "^25.1.1",
    "express": "^5.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.40.0",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/interaction": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/rrule": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "frappe-gantt": "^1.2.2",
    "gray-matter": "^4.0.3",
    "html2pdf.js": "^0.10.1",
    "ical.js": "^2.2.1",
    "isomorphic-git": "^1.37.4",
    "lucide-react": "^0.577.0",
    "mermaid": "^11.13.0",
    "node-pty": "^1.1.0",
    "pdfjs-dist": "^5.5.207",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.0",
    "rehype-react": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "rrule": "^2.8.1",
    "unified": "^11.0.5",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  }
}
